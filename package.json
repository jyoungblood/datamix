{
  "name": "datamix",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "check": "npm run typecheck",
    "smoke": "node --import tsx ./tests/smoke/datamix-smoke.mjs",
    "dev:admin": "npm run dev --workspace @datamix/admin",
    "dev:api": "npm run dev --workspace @datamix/api",
    "typegen:api": "npm run typegen --workspace @datamix/api",
    "clean": "node ./scripts/clean.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
