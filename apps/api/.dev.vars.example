APP_ENV=development
ADMIN_ORIGIN=http://127.0.0.1:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-string
AUTH_EMAIL_PROVIDER=resend
AUTH_EMAIL_FROM_EMAIL=noreply@example.com
AUTH_EMAIL_FROM_NAME=Datamix
AUTH_EMAIL_REPLY_TO_EMAIL=support@example.com
AUTH_RESEND_API_KEY=replace-with-resend-api-key
AUTH_SMTP_HOST=smtp.example.com
AUTH_SMTP_PORT=587
AUTH_SMTP_USERNAME=replace-with-smtp-username
AUTH_SMTP_PASSWORD=replace-with-smtp-password
AUTH_SMTP_TLS=starttls
