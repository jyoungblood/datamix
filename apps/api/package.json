{
  "name": "@datamix/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/logs wrangler dev --config wrangler.jsonc --port 8787",
    "build": "tsc -p tsconfig.json",
    "typegen": "WRANGLER_LOG_PATH=.wrangler/logs wrangler types ./worker-configuration.d.ts --config wrangler.jsonc",
    "typecheck": "WRANGLER_LOG_PATH=.wrangler/logs wrangler types ./worker-configuration.d.ts --config wrangler.jsonc --check && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@datamix/core": "0.0.0",
    "better-auth": "^1.6.9",
    "hono": "^4.10.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "wrangler": "^4.15.2"
  }
}
